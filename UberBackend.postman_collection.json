                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/nonexistent"
          }
        },
        {
          "name": "❌ No Auth Token (401)",
